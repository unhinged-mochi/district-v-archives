---
import "../styles/global.css";
import { Font } from "astro:assets";
import { getCollection } from "astro:content";
import { readFileSync } from "node:fs";
import yaml from "js-yaml";
import DesktopApp from "../components/DesktopApp";

// Load content collections
const charactersRaw = await getCollection("characters");
const daysRaw = await getCollection("days");
const factionsRaw = await getCollection("factions");
const sightingsRaw = await getCollection("sightings");

// Load relationships YAML
let relationships: unknown[] = [];
try {
  const relYaml = readFileSync("./src/content/relationships.yaml", "utf-8");
  const parsed = yaml.load(relYaml) as { relationships?: unknown[] };
  relationships = parsed?.relationships || [];
} catch (e) {
  console.warn("Could not load relationships.yaml:", e);
}

// Transform to plain objects for client-side
const characters = charactersRaw.map((c) => ({
  id: c.id,
  ...c.data,
  body: c.body || "",
}));

const days = daysRaw
  .map((d) => ({
    id: d.id,
    ...d.data,
    body: d.body || "",
  }))
  .sort((a, b) => a.day - b.day);

const factions = factionsRaw.map((f) => ({
  id: f.id,
  ...f.data,
  body: f.body || "",
}));

const sightings = sightingsRaw.map((s) => ({
  id: s.id,
  ...s.data,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" href="/favicon.ico">
    <meta name="generator" content={Astro.generator}>
    <title>LSPD Terminal // District V Archive</title>
    <meta
      name="description"
      content="Classified LSPD case files from the District V GTA RP event (Feb 21 - Mar 4, 2026)"
    >
    <meta name="theme-color" content="#FFB000">
    <Font cssVariable="--font-jetbrains-mono" preload />
  </head>
  <body>
    <DesktopApp
      client:load
      characters={characters}
      days={days}
      factions={factions}
      relationships={relationships}
      sightings={sightings}
    />
    <script>
      console.log(
        "%c LSPD TERMINAL v6.0.0 ",
        "background: #ffb000; color: #0a0a0a; font-weight: bold; font-family: monospace; padding: 4px 8px;"
      );
      console.log(
        "%c⚠ WARNING: Unauthorized access to this terminal is a federal offense.",
        "color: #ffb000; font-family: monospace;"
      );
      console.log(
        "%cCase #DV-2026-0221 // District V Archive // CLASSIFIED",
        "color: #ffb000; font-family: monospace; opacity: 0.6;"
      );
    </script>
  </body>
</html>
